ENV=staging
DATABASE_URL=postgresql://devsecops:staging-password@postgres:5432/devsecops_staging
JENKINS_BASE_URL=http://jenkins:8080
JENKINS_TOKEN=staging-token
STORAGE_PATH=/data/artifacts
SCAN_TIMEOUT=3600
LOG_LEVEL=INFO
DEBUG=false
MOCK_EXECUTION=false

POSTGRES_DB=devsecops_staging
